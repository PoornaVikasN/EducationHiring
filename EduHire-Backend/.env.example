# RxJobs4U API — Environment Variables
# Copy to .env and fill in real values. Never commit .env*.
# Var names match the existing project conventions you've populated.

# === GENERAL ===
NODE_ENV=development
SERVER_PORT=3001
TZ=UTC
CORS_ORIGINS=http://187.127.153.100:3000,http://localhost:3000,https://schoolteacher.co.in,https://www.schoolteacher.co.in,https://api.schoolteacher.co.in
# Set in prod when FE and API live on different subdomains of the same eTLD+1,
# e.g. ".schoolteacher.com" for FE on schoolteacher.com and API on api.schoolteacher.com.
# Leave blank in development (cookie defaults to the request host).
COOKIE_DOMAIN=.schoolteacher.co.in
# Public-facing frontend URL used in outbound alert links (email button, WhatsApp template).
# Defaults to https://schoolteacher.com when unset.
PUBLIC_FRONTEND_URL=https://schoolteacher.co.in

# === MONGODB ATLAS (M0 free tier is fine for MVP) ===
# URI is built in app.module.ts from these four parts.
MONGO_DB_USERNAME=
MONGO_DB_PASSWORD=
MONGO_DB_HOST=                              # e.g. cluster0.xxxxx.mongodb.net
MONGO_DB_NAME=eduhire

# === JWT — dual-token (access + refresh with rotation) ===
# Generate each secret independently: `openssl rand -hex 32`
JWT_ACCESS_SECRET=                          # ≥32 chars, keep private
JWT_REFRESH_SECRET=                         # ≥32 chars, DIFFERENT from ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === CONFIG ENCRYPTION (SystemConfig api_key field) ===
# ≥32 chars, MUST differ from JWT secrets. Generate: `openssl rand -hex 32`
# WARNING: rotating this key makes existing encrypted SystemConfig api_keys unreadable;
# admin must re-enter them via the Config page (Razorpay, AWS, MSG91, Google, Brevo, VAPID, etc.).
CONFIG_ENCRYPTION_KEY=

# === GOOGLE OAuth (Phase 3 — login with Google) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# === GOOGLE MAPS / PLACES (Phase 3 — location autocomplete + map picker) ===
# Free tier: $200/mo credit (covers ~28k map loads or ~70k autocomplete sessions).
# Restrict the key in Cloud Console to specific APIs + HTTP referrers.
GOOGLE_MAPS_API_KEY=

# === GSuite SMTP via nodemailer OAuth2 ===
# Generate at: https://developers.google.com/oauthplayground
# Scope needed: https://mail.google.com/
GMAIL_USER=                                 # e.g. noreply@schoolteacher.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=                         # optional — auto-refreshed from refresh token
SMTP_SENDER_NAME=RxJobs4U Admin

# === Google reCAPTCHA v3 ===
RECAPTCHA_SECRET_KEY=                       # server-side secret (never sent to browser)

# === AWS S3 (Phase 3 — resume / logo / certificate uploads via presigned PUT) ===
AWS_REGION=ap-south-1
AWS_BASE_URL=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === Wylto WhatsApp (OTP verification + SOS job alerts) ===
# Templates are hardcoded in the service: verify_code (OTP), sos_job_alert (SOS).
# Set this here for dev, or via Admin → API Keys for prod (no restart needed).
WYLTO_API_TOKEN=

# === RAZORPAY PAYMENTS (Phase 3) ===
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=   # You create this — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
